# ─── Q&Ace Runtime Environment ───
# Copy to .env and fill in real values

# Server
QACE_ENV=development
QACE_HOST=0.0.0.0
QACE_PORT=8000
QACE_LOG_LEVEL=info

# CORS (comma-separated origins)
QACE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# LLM provider: auto | groq | airforce
QACE_LLM_PROVIDER=auto

# Optional generic model override for either provider.
# Leave blank to use the provider-specific default below.
QACE_LLM_MODEL=

# Groq API
GROQ_API_KEY=gsk_your_key_here
QACE_GROQ_MODEL=llama-3.3-70b-versatile

# Airforce API
AIRFORCE_API_KEY=airforce_your_key_here
QACE_AIRFORCE_MODEL=deepseek-v3

# Model paths (relative to repo root)
QACE_MODEL_DIR=./models
QACE_WHISPER_MODEL=tiny.en
QACE_SILERO_ONNX=./models/silero-vad/silero_vad.onnx

# Perception models
# Voice model can be any Hugging Face repo compatible with Wav2Vec2 loading.
# Example from the older QnAce repo:
# QACE_VOCAL_MODEL=abdullahjamil42/QnAce-Voice-Model
QACE_VOCAL_MODEL=ehcalabres/wav2vec2-lg-xlsr-en-speech-emotion-recognition

# Face model is loaded from a local ONNX file. If your EfficientNet model lives in
# a Hugging Face repo, download/export it first, then point this to the local file.
# Older repo reference mentioned a HF-backed facial model source.
QACE_FACE_ONNX=./models/face-emotion/efficientnet_b2.onnx

# BERT text-quality model is also loaded from a local ONNX file.
# If your trained assets are stored in:
#   C:/22i-2451/QAce/FYP-QnAce-Main-Repo/BERT_Model
# then point QACE_BERT_ONNX to the exported .onnx file inside that folder, and
# optionally point QACE_BERT_TOKENIZER to the same folder if it contains tokenizer files.
QACE_BERT_ONNX=./models/text-quality/bert_quality.onnx
QACE_BERT_TOKENIZER=./models/text-quality

# RAG store
QACE_CHROMA_DIR=./data/chroma

# VAD tuning
QACE_VAD_SILENCE_MS=300
QACE_VAD_MIN_SPEECH_S=1.0

# Frontend (set in client/.env.local)
# NEXT_PUBLIC_QACE_API_URL=http://127.0.0.1:8000

# ── Supabase (coding round migrations + seed scripts) ──
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# SUPABASE_URL=https://[ref].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=[service_role JWT from Supabase → Settings → API]
