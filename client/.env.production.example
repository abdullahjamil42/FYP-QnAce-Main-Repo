# Vercel project → Settings → Environment Variables (set these for "Production")
# All three are exposed to the browser, so use the public anon key (NEVER the
# service-role key).

NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[anon public key from Supabase → Settings → API]

# Backend URL — once you add a custom domain + HTTPS this becomes
# https://api.yourdomain.com. Until then it can point straight at the
# Oracle VM IP, but mixed-content will block fetch() from a Vercel
# https origin, so a domain + cert is recommended for production.
NEXT_PUBLIC_QACE_API_URL=https://api.yourdomain.com
